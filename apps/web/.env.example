# =============================================================================
# apps/web 환경변수 예시 (MVP 다운그레이드 기준)
# =============================================================================
# 기본값(아무 env 없음) = MVP 모드: 외부 서비스 0으로 빌드·구동·견적 동작.
# 아래 기능 플래그를 켜면 해당 외부 의존이 활성화된다. 복원 절차는 FEATURES.md 참고.
#
# 로컬 개발 시에는 이 파일을 .env.local 로 복사해 값을 채운다.
#   cp .env.example .env.local
# =============================================================================

# ──────────────────────────────────────────────────────────────────────────
# 기능 플래그 (전부 미설정/`off` = MVP 모드)
# ──────────────────────────────────────────────────────────────────────────

# 견적 저장 (Supabase) — 고객 upsert · quote insert · 사진 업로드
#   off: 견적은 화면에만 표시(quoteId=null), DB 저장 안 함
#   on : 아래 Supabase 변수 필요
NEXT_PUBLIC_FEAT_QUOTE_PERSISTENCE=off

# 알림 (카카오 알림톡 / 알리고 SMS / Slack)
#   on 이려면 quotePersistence 도 on 이어야 의미 있음(quoteId 필요)
FEAT_NOTIFICATIONS=off

# 구독·결제 (Toss) — /subscribe, /account, /api/billing/*, /api/cron/billing
#   off: 관련 페이지는 / 로 redirect, billing API는 404
NEXT_PUBLIC_FEAT_BILLING=off

# ──────────────────────────────────────────────────────────────────────────
# Supabase  (NEXT_PUBLIC_FEAT_QUOTE_PERSISTENCE=on 또는 BILLING=on 일 때 필요)
# ──────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...
SUPABASE_SERVICE_KEY=sb_secret_...

# ──────────────────────────────────────────────────────────────────────────
# 알림  (FEAT_NOTIFICATIONS=on 일 때 — 하나 이상 설정. 없으면 graceful no-op)
# ──────────────────────────────────────────────────────────────────────────
# 관리자
ADMIN_SLACK_WEBHOOK=https://hooks.slack.com/services/...
ADMIN_PHONE=01000000000
# 알리고 SMS (고객 + 관리자 SMS)
ALIGO_API_KEY=your-aligo-api-key
ALIGO_USER_ID=your-aligo-user-id
ALIGO_SENDER_NUMBER=0200000000
# 카카오 알림톡 BizTalk (선택 — 없으면 SMS 자동 폴백)
KAKAO_BIZTALK_API_KEY=your-kakao-api-key
KAKAO_BIZTALK_SENDER_KEY=your-sender-key

# ──────────────────────────────────────────────────────────────────────────
# 결제 (Toss)  (NEXT_PUBLIC_FEAT_BILLING=on 일 때 필요)
# ──────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_TOSS_CLIENT_KEY=test_ck_...
TOSS_SECRET_KEY=test_sk_...
TOSS_WEBHOOK_SECRET=your-webhook-secret
# Vercel Cron 인증 (정기결제 배치 보호)
CRON_SECRET=your-cron-secret
